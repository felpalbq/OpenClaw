# --- Estado ---
# Arquivo de estado: state.json (produção) ou state_test.json (testes)
# Agentes e integrações leem/escrevem neste arquivo via state module
STATE_FILE=state.json

# --- LLM ---
LLM_PROVIDER=openai
LLM_API_KEY=sua-chave-aqui
LLM_MODEL=gpt-4o-mini

# --- OpenRouter ---
OPENROUTER_API_KEY=sua-chave-aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Workspace ---
WORKSPACE_DIR=./workspace

# --- Supabase ---
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-aqui
SUPABASE_SERVICE_KEY=sua-chave-aqui

# --- Google Cloud ---
GOOGLE_TOKEN_PATH=~/secure/google-token.json

# --- Telegram ---
TELEGRAM_TOKEN=seu-bot-token-aqui
TELEGRAM_CHAT_ID=seu-chat-id-aqui

# --- Trello ---
TRELLO_API_KEY=sua-chave-aqui
TRELLO_TOKEN=seu-token-aqui
TRELLO_API_SECRET=seu-secret-aqui